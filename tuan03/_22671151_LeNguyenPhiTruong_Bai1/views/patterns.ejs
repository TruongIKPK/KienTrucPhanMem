<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body>
  <section class="hero">
    <p class="badge">Kien truc phan mem</p>
    <h1><%= title %></h1>
    <p class="subtitle">
      Website demo cho 3 Design Pattern: Composite, Observer, Adapter.
      Co diagram, mo ta nguyen ly, va output thuc thi ngay tren giao dien.
    </p>
  </section>

  <section class="module-grid">
    <% modules.forEach(function(item) { %>
      <article class="module-card">
        <h2><%= item.name %></h2>
        <p class="icon"><%= item.icon %></p>
        <p><%= item.summary %></p>
        <ul>
          <% item.cases.forEach(function(useCase) { %>
            <li><%= useCase %></li>
          <% }) %>
        </ul>
      </article>
    <% }) %>
  </section>

  <section class="panel">
    <h2>1. Composite Diagram</h2>
    <div class="mermaid"><%- diagrams.composite %></div>
    <h2>2. Observer Diagram</h2>
    <div class="mermaid"><%- diagrams.observer %></div>
    <h2>3. Adapter Diagram</h2>
    <div class="mermaid"><%- diagrams.adapter %></div>
    <h2>4. Integration View</h2>
    <div class="mermaid"><%- diagrams.integration %></div>
  </section>

  <section class="panel">
    <h2>Runtime Output</h2>
    <div class="output-grid">
      <article class="output">
        <h3>Composite</h3>
        <pre><%= compositeOutput %></pre>
      </article>
      <article class="output">
        <h3>Observer</h3>
        <pre><%= observerOutput %></pre>
      </article>
      <article class="output">
        <h3>Adapter</h3>
        <pre><%= adapterOutput %></pre>
      </article>
    </div>
  </section>

  <section class="panel">
    <h2>Diagram Source</h2>
    <pre><%= diagramsDoc %></pre>
  </section>

  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({
      startOnLoad: true,
      theme: 'base',
      themeVariables: {
        primaryColor: '#E8F3FF',
        primaryTextColor: '#0d2138',
        primaryBorderColor: '#3A74B4',
        lineColor: '#2F5D91',
        fontFamily: 'Trebuchet MS, Segoe UI, sans-serif'
      }
    });
  </script>
</body>
</html>
