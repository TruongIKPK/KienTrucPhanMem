<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Error</title>
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body>
  <main class="panel">
    <h1><%= message %></h1>
    <h2><%= error && error.status ? error.status : 500 %></h2>
    <% if (error && error.stack) { %>
      <pre><%= error.stack %></pre>
    <% } %>
  </main>
</body>
</html>
