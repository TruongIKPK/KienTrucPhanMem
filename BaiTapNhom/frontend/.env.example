# API Gateway (recommended)
VITE_API_URL=http://localhost:8080/api

# Direct service URLs (fallback if no gateway)
VITE_USER_SERVICE_URL=http://localhost:8081
VITE_FOOD_SERVICE_URL=http://localhost:8082
VITE_ORDER_SERVICE_URL=http://localhost:8083
VITE_PAYMENT_SERVICE_URL=http://localhost:8084

# For LAN deployment, replace localhost with actual IP addresses:
# VITE_API_URL=http://192.168.1.104:8080/api
# VITE_USER_SERVICE_URL=http://192.168.1.101:8081
# etc.
